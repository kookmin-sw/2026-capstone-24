{
  "permissions": {
    "allow": [
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "mcp__UnityMCP__read_console",
      "mcp__UnityMCP__manage_asset",
      "mcp__UnityMCP__manage_components",
      "mcp__UnityMCP__manage_gameobject",
      "mcp__UnityMCP__manage_scene",
      "mcp__UnityMCP__find_gameobjects",
      "mcp__UnityMCP__refresh_unity"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/scripts/guard-unity-yaml.ps1\""
          }
        ]
      }
    ]
  }
}
